# Database (Neon PostgreSQL recommended for production)
# Neon provides automatic daily backups and point-in-time recovery (PITR) up to 7 days on Pro plan.
# Ensure PITR is enabled in the Neon dashboard: https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct connection (non-pooled) — required for prisma migrate deploy
# Same as DATABASE_URL but WITHOUT -pooler in the hostname
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Optional: Trust host for production
AUTH_TRUST_HOST=true

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# GitHub OAuth (https://github.com/settings/developers)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=""
EMAIL_FROM="AlgoStudio <onboarding@resend.dev>"

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Stripe Price IDs (create in Stripe Dashboard > Products)
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_ELITE_MONTHLY_PRICE_ID=""
STRIPE_INSTITUTIONAL_MONTHLY_PRICE_ID=""


# Sentry (error monitoring - https://sentry.io)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Analytics (optional - Plausible)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# PostHog (product analytics - https://posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# Uptime monitoring (protects cron endpoints)
CRON_SECRET=""

# Admin panel (email of the admin user who can manage tiers)
ADMIN_EMAIL=your-admin-email@example.com

# Track Record (HMAC signing for tamper-resistant checkpoints)
# Generate with: openssl rand -base64 32
TRACK_RECORD_SECRET=""

# Telegram Alerts (central bot — used for 1-click linking)
# Create a bot via @BotFather, then set the webhook with scripts/setup-telegram-webhook.ts
ALGO_TELEGRAM_BOT_TOKEN=""
ALGO_TELEGRAM_BOT_USERNAME=""
TELEGRAM_WEBHOOK_SECRET=""
