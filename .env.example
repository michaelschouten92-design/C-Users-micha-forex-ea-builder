# =============================================================================
# Algo Studio — Environment Variables
# =============================================================================
# Required in production are marked with [REQUIRED].
# Optional features degrade gracefully when left unset.
#
# For a complete deployment walkthrough see DEPLOY.md in the repo root.
# Generate secrets using the commands shown next to each var.
# =============================================================================

# -----------------------------------------------------------------------------
# Database [REQUIRED]
# -----------------------------------------------------------------------------
# Neon PostgreSQL recommended for production. Enable PITR backups on Pro plan.
# Dashboard: https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Direct connection (non-pooled) — required for `prisma migrate deploy`.
# Same as DATABASE_URL but WITHOUT -pooler in the hostname.
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# -----------------------------------------------------------------------------
# NextAuth [REQUIRED]
# -----------------------------------------------------------------------------
# Generate: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Production: your canonical domain (e.g. https://algo-studio.com)
# MUST NOT contain "localhost" in production — hard fail.
AUTH_URL="http://localhost:3000"

# Must be "true" in production behind a reverse proxy (Vercel).
AUTH_TRUST_HOST="false"

# Public app URL — used for emails and exported EA telemetry endpoints.
# MUST be set in production. Same as AUTH_URL for most deployments.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# OAuth Providers (optional)
# -----------------------------------------------------------------------------
# Google: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# GitHub: https://github.com/settings/developers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Discord: https://discord.com/developers/applications
# Optional — used for Discord login + automatic role sync based on subscription tier
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_BOT_TOKEN=""
DISCORD_GUILD_ID=""
DISCORD_PRO_ROLE_ID=""
DISCORD_ELITE_ROLE_ID=""

# -----------------------------------------------------------------------------
# Email [REQUIRED in prod]
# -----------------------------------------------------------------------------
# Resend API key: https://resend.com/api-keys
RESEND_API_KEY=""

# IMPORTANT: In production, EMAIL_FROM must use a verified domain.
# The default "onboarding@resend.dev" is the Resend sandbox and will be
# rejected by SPF/DKIM filters at most mail providers.
# Set up a custom domain in Resend and add the DNS records BEFORE going live.
EMAIL_FROM="Algo Studio <noreply@algo-studio.com>"

# -----------------------------------------------------------------------------
# Stripe Payments [REQUIRED in prod]
# -----------------------------------------------------------------------------
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Price IDs — create in Stripe Dashboard > Products
STRIPE_PRO_MONTHLY_PRICE_ID=""
STRIPE_ELITE_MONTHLY_PRICE_ID=""
STRIPE_INSTITUTIONAL_MONTHLY_PRICE_ID=""

# Free trial length (days) — optional, 0-90
STRIPE_TRIAL_DAYS="14"

# Optional IP allowlist for Stripe webhook endpoint (comma-separated)
# STRIPE_WEBHOOK_IPS="3.18.12.63,3.130.192.231"

# -----------------------------------------------------------------------------
# Upstash Redis [REQUIRED in prod]
# -----------------------------------------------------------------------------
# Distributed rate limiting across serverless instances.
# Dashboard: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# Cryptographic Keys [REQUIRED in prod]
# -----------------------------------------------------------------------------
# Cron job auth — generate: openssl rand -base64 32
CRON_SECRET=""

# Internal service-to-service API key — generate: openssl rand -base64 32
# Used by internal routes under /api/internal/*
INTERNAL_API_KEY=""

# Field-level encryption salt — generate: openssl rand -hex 32
# Used for encrypting telegram bot tokens and other sensitive user data.
ENCRYPTION_SALT=""

# Previous encryption salt (optional) — for zero-downtime key rotation.
# Allows decryption of values encrypted with the previous salt.
ENCRYPTION_SALT_PREVIOUS=""

# Track record cryptographic signing key (min 64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TRACK_RECORD_SIGNING_KEY=""

# Track record checkpoint HMAC secret — generate: openssl rand -hex 32
TRACK_RECORD_SECRET=""

# Internal trade ingest HMAC secret — generate: openssl rand -hex 32
# Used by machine-to-machine trade import pipelines.
INGEST_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# Error Monitoring (optional but recommended)
# -----------------------------------------------------------------------------
# Sentry: https://sentry.io
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# -----------------------------------------------------------------------------
# Bot Protection / CAPTCHA (optional)
# -----------------------------------------------------------------------------
# Cloudflare Turnstile: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# -----------------------------------------------------------------------------
# Telegram Bot (optional — alert channel)
# -----------------------------------------------------------------------------
# Create bot via @BotFather on Telegram. Used for 1-click alert linking.
# Set up the webhook with scripts/setup-telegram-webhook.ts after deployment.
ALGO_TELEGRAM_BOT_TOKEN=""
ALGO_TELEGRAM_BOT_USERNAME=""
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# Web Push Notifications (optional)
# -----------------------------------------------------------------------------
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:support@algo-studio.com"

# -----------------------------------------------------------------------------
# Product Analytics (optional — PostHog)
# -----------------------------------------------------------------------------
# PostHog EU Cloud recommended for GDPR (eu.i.posthog.com).
# Dashboard: https://eu.posthog.com
# NOTE: When enabled, disclose PostHog as a processor in your privacy policy
# and gate loading behind cookie consent (not "essential").
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# -----------------------------------------------------------------------------
# AI Providers (optional — powers "AI Strategy Doctor" feature)
# -----------------------------------------------------------------------------
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Alternative AI provider (optional)
ANTHROPIC_API_KEY=""

# -----------------------------------------------------------------------------
# Admin & Support
# -----------------------------------------------------------------------------
# Bootstrap admin — email of the user who gets automatic admin access
ADMIN_EMAIL="your-admin-email@example.com"

# Support contact (shown in UI + email footers)
SUPPORT_EMAIL="support@algo-studio.com"
